# Kylas CRM
KYLAS_API_KEY=your-uuid-here:tenantId

# Airtable — Kylas CRM - Sales Pipeline base (Contacts, Deals, Sync Log)
AIRTABLE_PAT=patXXXXXXXXXXXXXX
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX

# Airtable — Company Database base (Company List)
AIRTABLE_COMPANY_BASE_ID=appXXXXXXXXXXXXXX

# Resend (email alerts)
RESEND_API_KEY=re_XXXXXXXXXXXXXXXX
RESEND_FROM_EMAIL=onboarding@resend.dev
ALERT_EMAIL=you@example.com

# ── Cold Call Analysis System (cold_call/) ──────────────────────────────────────
# Google Drive — service account JSON (a file path OR the raw JSON string)
GOOGLE_SERVICE_ACCOUNT_JSON=path/to/service_account.json
GOOGLE_DRIVE_FOLDER_ID=your_calls_folder_id
# Transcription (Hugging Face) + analysis (Gemini)
HF_API_TOKEN=hf_XXXXXXXXXXXX
GEMINI_API_KEY=AIzaXXXXXXXXXX
# Dedicated Airtable base for the `Calls` table (token reuses AIRTABLE_PAT above)
COLD_CALL_AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX
# RESEND_API_KEY above is reused; set the coaching sender if different:
# RESEND_FROM_EMAIL=coaching@enout.in
